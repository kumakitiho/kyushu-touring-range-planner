{
  "name": "kyushu-touring-range-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-spots": "npm run candidate-limit && node scripts/apply-weekly-gourmet-spots.mjs",
    "dev": "npm run prepare-spots && concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "npm run prepare-spots && tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "npm run prepare-spots && tsx server/index.ts",
    "test": "npm run prepare-spots && vitest run",
    "spots:images": "node scripts/enrich-spot-images.mjs",
    "candidate-limit": "node scripts/set-candidate-limit.mjs",
    "spots:weekly-gourmet": "node scripts/apply-weekly-gourmet-spots.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.0",
    "jsdom": "^27.3.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.0.16"
  }
}
